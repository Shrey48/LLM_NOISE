  "@type": "sc:Dataset",
  "name": "alphaK Knowledge-Check Dataset for Alpha-Asynchronous ECA Noise",
  "description": "200-question knowledge-check dataset for alpha-asynchronous ECA noise. Designed to verify that LLM failures on the identification task reflect structural limitations rather than missing domain knowledge. Questions span 6 topics in MCQ (178) and short-answer (22) formats across three difficulty levels: Easy (80), Medium (68), Hard (52). Scored by independent judge model (Grok-3).",
  "url": "https://anonymous.4open.science/r/LLM_NOISE-9DC1",
  "license": "https://spdx.org/licenses/CC-BY-4.0.html",
  "datePublished": "2026-05-04",
  "creator": [
    {
      "@type": "sc:Person",
      "sc:name": "Anonymous Author",
      "sc:email": "anonymous@example.com"
    }
  ],
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "rai:dataBiases": "No bias \u2014 dataset consists of authored mathematical and definitional questions about ECA noise mechanics. No human subject data, no demographic information. Questions are grounded in first principles.",
  "rai:dataLimitations": "Limited to alpha-asynchronous noise domain only. 200 questions may not cover all aspects of the noise model. Short-answer scoring depends on judge model (Grok-3) which may have its own limitations.",
  "rai:dataUseCases": "Established: diagnosing whether LLM failures on alphaECA identification reflect missing domain knowledge vs architectural limitations; evaluating LLM mathematical reasoning about stochastic update mechanics. Not established: general LLM benchmarking outside CA domain.",
  "rai:personalSensitiveInformation": "None. The dataset contains no personal or sensitive information of any kind. All data is fully synthetically generated from elementary cellular automata simulations. No human subjects, demographic data, geographic data, health data, political or religious beliefs, or any other personally identifiable information is present.",
  "rai:hasSyntheticData": true,
  "prov:wasDerivedFrom": "The dataset is not derived from any existing dataset. All data is generated from first principles using elementary cellular automata simulation code. The ECA rule space (256 rules) follows the standard Wolfram ECA rule numbering scheme. No external data sources were used.",
  "prov:wasGeneratedBy": "Fully synthetically generated using deterministic simulation code at https://anonymous.4open.science/r/LLM_NOISE-9DC1. Rule partition: 256 ECA rules permuted under numpy.random.default_rng(seed=42), split 179 train / 77 test, strictly disjoint. Initial configurations sampled uniformly from {0,1}^n subject to non-triviality constraint (rejection sampling).",
  "rai:dataSocialImpact": "Positive impacts: advances scientific understanding of LLM reasoning over spatiotemporal data, contributes reproducible benchmarks for the ML community, and provides open tools for studying noise robustness in dynamical systems. The dataset is fully synthetic with no human subjects, eliminating risks of privacy violation or demographic harm. Negative impacts or misuse risks: minimal given the purely synthetic and abstract nature of the data. Not intended for safety-critical, clinical, or socially consequential decision-making.",
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "alphak_questions",
      "name": "eca_alpha_async_knowledge_check",
      "description": "200 knowledge-check questions for alpha-asynchronous ECA noise in MCQ and short-answer format.",
      "contentUrl": "https://anonymous.4open.science/r/LLM_NOISE-9DC1/blob/main/dataset/eca_knowledgecheck_dataset/alpha_async/eca_alpha_async_knowledge_check.json",
      "encodingFormat": "application/json",
      "md5": "c23b7440bd3b3247304955abc60cd67f"
    },
    {
      "@type": "cr:FileObject",
      "@id": "alphak_metadata",
      "name": "metadata_alpha_async",
      "description": "Metadata for the alphaK knowledge-check dataset.",
      "contentUrl": "https://anonymous.4open.science/r/LLM_NOISE-9DC1/blob/main/dataset/eca_knowledgecheck_dataset/alpha_async/metadata_alpha_async.json",
      "encodingFormat": "application/json",
      "md5": "88b4e87fe015337fc8c773f341a3850b"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "alphaK_records",
      "name": "alphaK_records",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "alphaK_records/question",
          "name": "question",
          "description": "Knowledge-check question text",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "alphak_questions"
            },
            "extract": {
              "column": "question"
            }
          }
        }
      ]
    }
  ]
}